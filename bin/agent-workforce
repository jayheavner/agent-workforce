#!/usr/bin/env bash
# agent-workforce — start the team, guaranteed fresh.
#
# Snapshot mode is primary: plugin-shipped agents ignore `hooks`,
# `permissionMode`, and `mcpServers` frontmatter (documented Claude Code
# behavior), which live plugin mode would silently drop — costing per-role
# enforcement and no-prompt autonomy. So this launcher installs the current
# checkout into the active profile whenever it is stale, then starts the
# orchestrator. A stale profile can no longer be run quietly: the previous
# generation's dominant failure was fixes that sat merged-but-uninstalled.
#
# Usage:
#   bin/agent-workforce [claude args...]          # freshen + launch orchestrator
#   CLAUDE_CONFIG_DIR=~/.claude-work bin/agent-workforce
#   bin/agent-workforce --no-install [args...]    # skip the freshness check
#   bin/agent-workforce --plugin [args...]        # legacy live plugin mode
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

for command in claude jq python3; do
  if ! command -v "$command" >/dev/null 2>&1; then
    printf 'agent-workforce: required command not found: %s\n' "$command" >&2
    exit 1
  fi
done

MODE="snapshot"
SKIP_INSTALL=0
ARGS=()
for a in "$@"; do
  case "$a" in
    --plugin) MODE="plugin" ;;
    --no-install) SKIP_INSTALL=1 ;;
    *) ARGS+=("$a") ;;
  esac
done

if [ "$MODE" = "plugin" ]; then
  # Legacy live plugin mode: hooks route through hooks.json + the router, but
  # per-agent permissionMode is NOT honored — expect permission prompts.
  # Bash 3.2 with `set -u` treats an empty array expansion as unbound; the
  # `+word` form keeps a zero-arg launch safe (same idiom as install.sh).
  exec claude --plugin-dir "$ROOT" ${ARGS[@]+"${ARGS[@]}"}
fi

PROFILE="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
MANIFEST="$PROFILE/agent-team-manifest.json"
ORIGIN_STATUS="$PROFILE/agent-team-origin-status.json"

self_update() {
  # A stale CLONE self-certifies as fresh: needs_install compares the profile
  # to the local working tree only, so a checkout behind origin runs old code
  # silently (2026-07-22: build 187007b ran two days behind and missed the
  # transcript archiver entirely; the evidence traveled by iCloud). Decision
  # 2026-07-22: auto-update — fetch origin, fast-forward when clean, and
  # record the remaining deficit for the cost report to stamp. Every failure
  # path is soft: offline, diverged, or dirty never blocks a launch.
  local behind=0 checked_at
  checked_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  if git -C "$ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1 \
     && [ "$(git -C "$ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null)" = "main" ]; then
    if GIT_SSH_COMMAND="ssh -o ConnectTimeout=5 -o BatchMode=yes" \
       git -C "$ROOT" -c http.lowSpeedLimit=1000 -c http.lowSpeedTime=10 \
       fetch --quiet origin main 2>/dev/null; then
      behind="$(git -C "$ROOT" rev-list --count HEAD..origin/main 2>/dev/null || echo 0)"
      [ -n "$behind" ] || behind=0
      if [ "$behind" -gt 0 ]; then
        if [ -z "$(git -C "$ROOT" status --porcelain 2>/dev/null)" ] \
           && git -C "$ROOT" merge-base --is-ancestor HEAD origin/main 2>/dev/null; then
          echo "agent-workforce: checkout is $behind commit(s) behind origin/main — fast-forwarding..." >&2
          if git -C "$ROOT" merge --ff-only --quiet origin/main >&2 2>&1; then
            behind=0
          else
            echo "agent-workforce: fast-forward failed — launching from the stale checkout." >&2
          fi
        else
          echo "agent-workforce: checkout is $behind commit(s) behind origin/main but has local changes or divergence — launching anyway; reconcile manually." >&2
        fi
      fi
    else
      echo "agent-workforce: could not reach origin to check freshness (offline?) — launching from the local checkout." >&2
    fi
  fi
  mkdir -p "$PROFILE" 2>/dev/null || true
  printf '{"behind": %s, "checked_at": "%s"}\n' "$behind" "$checked_at" \
    > "$ORIGIN_STATUS" 2>/dev/null || true
}

needs_install() {
  [ -f "$MANIFEST" ] || return 0
  # Stale when the repo working tree differs in any installed file from what
  # the manifest recorded — cheap sha comparison over the manifest's own list.
  python3 - "$MANIFEST" "$ROOT" <<'PY'
import hashlib, json, os, sys
manifest_path, root = sys.argv[1], sys.argv[2]
try:
    with open(manifest_path) as f:
        m = json.load(f)
except Exception:
    sys.exit(0)  # unreadable manifest -> install
files = m.get("files") or {}
if not files:
    sys.exit(0)
repo_files = set()
for d, sub in (("agents", "agents"), ("hooks", "hooks")):
    p = os.path.join(root, d)
    if os.path.isdir(p):
        for fn in os.listdir(p):
            if os.path.isfile(os.path.join(p, fn)):
                repo_files.add(f"{sub}/{fn}")
for dirpath, _, fns in os.walk(os.path.join(root, "skills")):
    for fn in fns:
        rel = os.path.relpath(os.path.join(dirpath, fn), root)
        repo_files.add(rel)
recorded = set(files)
if repo_files != recorded:
    sys.exit(0)  # added or removed files -> install
for rel, sha in files.items():
    path = os.path.join(root, rel)
    try:
        h = hashlib.sha256(open(path, "rb").read()).hexdigest()
    except OSError:
        sys.exit(0)
    if h != sha:
        sys.exit(0)  # changed content -> install
sys.exit(1)  # everything matches -> fresh
PY
}

if [ "$SKIP_INSTALL" -eq 0 ]; then
  self_update
fi

if [ "$SKIP_INSTALL" -eq 0 ] && needs_install; then
  echo "agent-workforce: profile $PROFILE is stale — installing current checkout..." >&2
  if ! AGENT_TEAM_SKIP_INSTALL_TEST=1 bash "$ROOT/install.sh" --profile "$PROFILE" >&2; then
    printf 'agent-workforce: install failed — refusing to launch a stale team.\nRun: bash %s/install.sh --profile %s\n' "$ROOT" "$PROFILE" >&2
    exit 1
  fi
fi

# Hook health is reported on stderr before launch AND after exit. The
# fullscreen TUI wipes the pre-launch line, and anything printed mid-session
# scrolls away — the post-exit line is the one that stays on the terminal
# (2026-07-20 log: two hooks failed 'Permission denied' on every command and
# no one was ever shown the fix). The probe never blocks a launch, and the
# repair is deliberately left to the human: agents must not modify hook
# infrastructure, so the launcher only names the exact chmod.
hook_health_report() {
  AGENT_TEAM_PROFILE="$PROFILE" python3 "$ROOT/hooks/cost_report.py" --hook-health >&2 || true
}

# The orchestrator's main session runs bypassPermissions by decision
# (2026-07-19): the human is not watching, every specialist already bypasses,
# and prompts wedge autonomy. The contract + audit log remain the controls on
# the orchestrator's read-only shell. A flag passed by the caller comes later
# on the command line and therefore wins. claude is no longer exec'd so the
# post-exit health report can run; the session's exit code is preserved.
hook_health_report
status=0
claude --agent orchestrator --permission-mode bypassPermissions ${ARGS[@]+"${ARGS[@]}"} || status=$?
hook_health_report
exit "$status"
