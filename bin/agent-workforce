#!/usr/bin/env bash
# Start Claude Code with this checkout loaded directly as a development plugin.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

for command in claude jq; do
  if ! command -v "$command" >/dev/null 2>&1; then
    printf 'agent-workforce: required command not found: %s\n' "$command" >&2
    exit 1
  fi
done

exec claude --plugin-dir "$ROOT" "$@"
