#!/usr/bin/env python3
"""Operate and inspect durable Agent Workforce process-assurance state."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT / "hooks"))

from process_assurance import AssuranceError, AssuranceStore, canonical_json  # noqa: E402


def _input(path: str | None) -> dict[str, Any]:
    """Read one JSON object from a file or standard input."""
    if path in {None, "-"}:
        value = json.load(sys.stdin)
    else:
        value = json.loads(Path(path).read_text(encoding="utf-8"))
    if not isinstance(value, dict):
        raise AssuranceError("INVALID_WIRE_VALUE: command input must be an object")
    return value


def _run(store: AssuranceStore, command: str, path: str | None) -> object:
    """Execute one exact state-owner operation."""
    if command == "status" or command == "verify":
        return store.read_state()
    if command == "metrics":
        return store.metrics_report()
    value = _input(path)
    if command == "charter-init":
        return store.initialize_charter(value)
    if command == "audit-request":
        return store.request_audit(value)
    if command == "audit-result":
        return store.record_assessment(str(value.pop("request_id", "")), value)
    if command == "amendment-propose":
        return store.propose_amendment(value)
    if command == "amendment-assess":
        return store.assess_amendment(str(value.pop("proposal_id", "")), value)
    if command == "amendment-decide":
        return store.decide_amendment(str(value.pop("proposal_id", "")), value)
    if command == "effectiveness-record":
        return store.record_effectiveness_outcome(value)
    raise AssuranceError(f"INVALID_WIRE_VALUE: unknown command {command}")


def main(arguments: list[str]) -> int:
    """Parse CLI arguments and emit one canonical JSON result."""
    parser = argparse.ArgumentParser()
    parser.add_argument("--state-root", type=Path, required=True)
    parser.add_argument("--session", required=True)
    parser.add_argument("--mode", choices=("OFF", "SHADOW", "ENFORCE"), required=True)
    parser.add_argument(
        "command",
        choices=(
            "charter-init",
            "audit-request",
            "audit-result",
            "amendment-propose",
            "amendment-assess",
            "amendment-decide",
            "effectiveness-record",
            "status",
            "metrics",
            "verify",
        ),
    )
    parser.add_argument("input", nargs="?")
    options = parser.parse_args(arguments)
    try:
        result = _run(
            AssuranceStore(options.state_root, options.session, mode=options.mode),
            options.command,
            options.input,
        )
    except (AssuranceError, OSError, json.JSONDecodeError) as error:
        print(f"agent-workforce-process-assurance: {error}", file=sys.stderr)
        return 2
    sys.stdout.buffer.write(canonical_json(result) + b"\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
